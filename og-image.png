<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="glow" cx="50%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#1B2D45" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#0D1B2A" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="signalLine" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#2D7FF9" stop-opacity="0"/>
      <stop offset="25%" stop-color="#2D7FF9" stop-opacity="1"/>
      <stop offset="75%" stop-color="#2D7FF9" stop-opacity="1"/>
      <stop offset="100%" stop-color="#2D7FF9" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="signalFade" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#2D7FF9" stop-opacity="0"/>
      <stop offset="25%" stop-color="#2D7FF9" stop-opacity="0.25"/>
      <stop offset="75%" stop-color="#2D7FF9" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#2D7FF9" stop-opacity="0"/>
    </linearGradient>
    <!-- Data grid pattern -->
    <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
      <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#2D7FF9" stroke-width="0.4" stroke-opacity="0.08"/>
    </pattern>
  </defs>

  <!-- Background Deep Navy -->
  <rect width="1200" height="630" fill="#0D1B2A"/>
  <!-- Grid texture -->
  <rect width="1200" height="630" fill="url(#grid)"/>
  <!-- Center glow -->
  <rect width="1200" height="630" fill="url(#glow)"/>

  <!-- Corner marks -->
  <line x1="72" y1="72" x2="112" y2="72" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="72" y1="72" x2="72" y2="112" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="1128" y1="72" x2="1088" y2="72" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="1128" y1="72" x2="1128" y2="112" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="72" y1="558" x2="112" y2="558" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="72" y1="558" x2="72" y2="518" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="1128" y1="558" x2="1088" y2="558" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>
  <line x1="1128" y1="558" x2="1128" y2="518" stroke="#2D7FF9" stroke-opacity="0.4" stroke-width="1.5"/>

  <!-- Signal line top -->
  <rect x="0" y="0" width="1200" height="3" fill="url(#signalLine)"/>

  <!-- SIGHTLINE wordmark — Space Grotesk Bold style, centered -->
  <text
    x="600" y="300"
    font-family="'Arial Black', 'Helvetica Neue', Arial, sans-serif"
    font-size="112"
    font-weight="900"
    letter-spacing="14"
    fill="#FFFFFF"
    text-anchor="middle"
    dominant-baseline="middle"
  >SIGHTLINE</text>

  <!-- ADVISORY — Electric Blue, spaced -->
  <text
    x="600" y="392"
    font-family="'Arial', 'Helvetica Neue', sans-serif"
    font-size="24"
    font-weight="400"
    letter-spacing="20"
    fill="#2D7FF9"
    text-anchor="middle"
    dominant-baseline="middle"
  >ADVISORY</text>

  <!-- Signal line under ADVISORY -->
  <rect x="200" y="430" width="800" height="1" fill="url(#signalFade)"/>

  <!-- Tagline -->
  <text
    x="600" y="492"
    font-family="'Arial', 'Helvetica Neue', sans-serif"
    font-size="14"
    font-weight="400"
    letter-spacing="5"
    fill="#FFFFFF"
    fill-opacity="0.35"
    text-anchor="middle"
  >PARA EMPRESARIOS QUE YA CRECIERON</text>

  <!-- URL -->
  <text
    x="600" y="542"
    font-family="'Courier New', monospace"
    font-size="13"
    letter-spacing="3"
    fill="#2D7FF9"
    fill-opacity="0.5"
    text-anchor="middle"
  >sightlineadvisory.co</text>

  <!-- Signal line bottom -->
  <rect x="0" y="627" width="1200" height="3" fill="url(#signalFade)"/>
</svg>
